@prefix : <http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix time: <http://www.w3.org/2006/time#> .
@base <http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/> .

<http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology> rdf:type owl:Ontology ;
                                                                                          rdfs:comment """Ontology Mapping the Semiconductor Supply Chain Assumptions used within the Work of the Industrial Alliance on Processors and Semiconductor Technologies.
Integration of Semiconductor Industry Market Capitalization for Stress Test Working Group.""" ;
                                                                                          rdfs:isDefinedBy """Yannic Schlosser (GSD SID IN)
Christine O'Brien (GSD SID IN)""" .

#################################################################
#    Annotation properties
#################################################################

###  http://www.w3.org/2006/time#inXSDDateTimeStamp
time:inXSDDateTimeStamp rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/flowsGoodsTo
:flowsGoodsTo rdf:type owl:ObjectProperty ;
              owl:inverseOf :recievesGoodsFrom ;
              rdfs:domain :Cluster ;
              rdfs:range :Cluster .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/flowsInformationTo
:flowsInformationTo rdf:type owl:ObjectProperty ;
                    owl:inverseOf :recievesInformationFrom ;
                    rdfs:domain :Cluster ;
                    rdfs:range :Cluster .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/flowsMoneyTo
:flowsMoneyTo rdf:type owl:ObjectProperty ;
              owl:inverseOf :recievesMoneyFrom ;
              rdfs:domain :Cluster ;
              rdfs:range :Cluster .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/hasCompany
:hasCompany rdf:type owl:ObjectProperty ;
            owl:inverseOf :isInCluster ;
            rdfs:domain :Cluster ;
            rdfs:range :Company .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/hasHeadquartersIn
:hasHeadquartersIn rdf:type owl:ObjectProperty ;
                   rdfs:domain :Organisation ;
                   rdfs:range :Region ;
                   rdfs:comment "Associates an Organisation (e.g. Company) with the Region in which its corporate headquarters are located. Enables regional aggregation of market capitalization and supply-chain exposure." .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/isInCluster
:isInCluster rdf:type owl:ObjectProperty ;
             rdfs:domain :Company ;
             rdfs:range :Cluster .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/recievesGoodsFrom
:recievesGoodsFrom rdf:type owl:ObjectProperty ;
                   rdfs:domain :Cluster ;
                   rdfs:range :Cluster .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/recievesInformationFrom
:recievesInformationFrom rdf:type owl:ObjectProperty ;
                         rdfs:domain :Cluster ;
                         rdfs:range :Cluster .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/recievesMoneyFrom
:recievesMoneyFrom rdf:type owl:ObjectProperty ;
                   rdfs:domain :Cluster ;
                   rdfs:range :Cluster .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/reportsOnCluster
:reportsOnCluster rdf:type owl:ObjectProperty ;
                  rdfs:domain :Market_Capitalization ;
                  rdfs:range :Cluster .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/reportsOnCompany
:reportsOnCompany rdf:type owl:ObjectProperty ;
                  rdfs:domain :Market_Capitalization ;
                  rdfs:range :Company .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/reportsOnRegion
:reportsOnRegion rdf:type owl:ObjectProperty ;
                 rdfs:domain :Regional_Concentration ;
                 rdfs:range :Region ;
                 rdfs:comment "Links a Regional_Concentration report to the Region it characterises (e.g. share of global market capitalization or supply-chain capacity attributed to that Region)." .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/snapshotDate
:snapshotDate rdf:type owl:ObjectProperty ;
              rdfs:domain :Market_Capitalization .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/hasMarketCapitalizationValueBillionsUSD
:hasMarketCapitalizationValueBillionsUSD rdf:type owl:DatatypeProperty ;
                                         rdfs:domain :Market_Capitalization ;
                                         rdfs:range xsd:decimal .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/hasProportionInCluster
:hasProportionInCluster rdf:type owl:DatatypeProperty ;
                        rdfs:domain :Market_Capitalization ;
                        rdfs:range xsd:decimal .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology#China
:China rdf:type owl:Class ;
       rdfs:subClassOf :Region .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology#Japan
:Japan rdf:type owl:Class ;
       rdfs:subClassOf :Region .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology#Other
:Other rdf:type owl:Class ;
       rdfs:subClassOf :Region .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology#South_Korea
:South_Korea rdf:type owl:Class ;
             rdfs:subClassOf :Region .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology#Taiwan
:Taiwan rdf:type owl:Class ;
        rdfs:subClassOf :Region .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology#USA
:USA rdf:type owl:Class ;
     rdfs:subClassOf :Region .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/Applications_Cluster
:Applications_Cluster rdf:type owl:Class ;
                      rdfs:subClassOf :Customer_Cluster .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/Associations_and_Others_Cluster
:Associations_and_Others_Cluster rdf:type owl:Class ;
                                 rdfs:subClassOf :Industrial_Alliance_Supply_Chain_Cluster .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/Cluster
:Cluster rdf:type owl:Class ;
         rdfs:comment "Top-level class representing a grouping of organisations (typically companies) that share a common role, function, or position within the semiconductor supply chain or its surrounding ecosystem. Subclasses partition the ecosystem into supply-chain segments (Industrial_Alliance_Supply_Chain_Cluster) and downstream customer segments (Customer_Cluster)." .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/Company
:Company rdf:type owl:Class ;
         rdfs:subClassOf :Organisation ;
         rdfs:comment "A commercial Organisation (legal entity) that participates in the semiconductor value chain, either as a supplier within the Industrial Alliance supply chain or as a downstream customer. A Company is assigned to one or more Clusters via the isInCluster property and is the subject of Market_Capitalization reports." .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/Components_Cluster
:Components_Cluster rdf:type owl:Class ;
                    rdfs:subClassOf :Customer_Cluster .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/Customer_Cluster
:Customer_Cluster rdf:type owl:Class ;
                  rdfs:subClassOf :Industrial_Alliance_Supply_Chain_Cluster .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/Electronic_Manufacturing_Services_and_Original_Design_Manufacturer_Cluster
:Electronic_Manufacturing_Services_and_Original_Design_Manufacturer_Cluster rdf:type owl:Class ;
                                                                            rdfs:subClassOf :Customer_Cluster .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/Equipment_Cluster
:Equipment_Cluster rdf:type owl:Class ;
                   rdfs:subClassOf :Industrial_Alliance_Supply_Chain_Cluster .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/Fabless_Cluster
:Fabless_Cluster rdf:type owl:Class ;
                 rdfs:subClassOf :Industrial_Alliance_Supply_Chain_Cluster .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/Industrial_Alliance_Supply_Chain_Cluster
:Industrial_Alliance_Supply_Chain_Cluster rdf:type owl:Class ;
                                          rdfs:subClassOf :Cluster ;
                                          rdfs:comment "A Cluster representing one of the segments of the semiconductor supply chain as defined by the Industrial Alliance on Processors and Semiconductor Technologies. Subclasses cover the full upstream value chain (e.g. Materials, Equipment, IP/EDA, Fabless, Silicon Foundry/IDM Frontend, OSAT/IDM Backend, Photonics, R&D/Academia, Associations) as well as downstream Customer_Cluster segments." .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/Intellectual_Property_and_Electronic_Design_Automation_Cluster
:Intellectual_Property_and_Electronic_Design_Automation_Cluster rdf:type owl:Class ;
                                                                rdfs:subClassOf :Industrial_Alliance_Supply_Chain_Cluster .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/Market_Capitalization
:Market_Capitalization rdf:type owl:Class ;
                       rdfs:subClassOf :Report ;
                       rdfs:comment """MC_j = SUM over i in Co of (P_ij * MC_i).
MC_i = hasMarketCapitalizationValueUSD on this individual.
P_ij = hasProportionInCluster on this individual (preliminary assumption, to be refined).
Co = all Company individuals. Sum of hasProportionInCluster per company across all clusters = 1.0.""" .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/Materials_Cluster
:Materials_Cluster rdf:type owl:Class ;
                   rdfs:subClassOf :Industrial_Alliance_Supply_Chain_Cluster .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/Organisation
:Organisation rdf:type owl:Class ;
              rdfs:comment "A legal or institutional entity (e.g. company, association, research institute, public body) that can participate in the semiconductor ecosystem. Serves as the superclass of Company and provides a generic anchor for any organisational actor referenced in the ontology." .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/Outsourced_Semiconductor_Assembly_and_Test_and_Integrated_Device_Manufacturer_Backend_Cluster
:Outsourced_Semiconductor_Assembly_and_Test_and_Integrated_Device_Manufacturer_Backend_Cluster rdf:type owl:Class ;
                                                                                               rdfs:subClassOf :Industrial_Alliance_Supply_Chain_Cluster .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/Photonics_Cluster
:Photonics_Cluster rdf:type owl:Class ;
                   rdfs:subClassOf :Industrial_Alliance_Supply_Chain_Cluster .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/Region
:Region rdf:type owl:Class ;
        rdfs:comment "A geographic area (typically a country or country group) used to localise actors and aggregate market data within the semiconductor ecosystem. Subclasses cover the regions most relevant to semiconductor market capitalization analysis: USA, China, Taiwan, South_Korea, Japan, and Other. Linked to Organisation via hasHeadquartersIn and to Regional_Concentration via reportsOnRegion." .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/Regional_Concentration
:Regional_Concentration rdf:type owl:Class ;
                        rdfs:subClassOf :Report .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/Report
:Report rdf:type owl:Class ;
        rdfs:comment "Top-level class for market analysis reports. Subclass: Market_Capitalization " .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/Silicon_Foundry_and_Integrated_Device_Manufacturer_Frontend_Cluster
:Silicon_Foundry_and_Integrated_Device_Manufacturer_Frontend_Cluster rdf:type owl:Class ;
                                                                     rdfs:subClassOf :Industrial_Alliance_Supply_Chain_Cluster .


###  http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/Research_&_Development_and_Academia_Cluster
<http://www.semanticweb.org/schlosseryan/ontologies/2026/2/MarketCapitalizationOntology/Research_&_Development_and_Academia_Cluster> rdf:type owl:Class ;
                                                                                                                                     rdfs:subClassOf :Industrial_Alliance_Supply_Chain_Cluster .


